{
  "$schema_version": "1.0",
  "model": "claude",
  "family": "claude",
  "display_name": "Claude (Anthropic)",
  "date": "2026-02-26",
  "scoring": { "normalization_base": 500, "min_word_count": 30 },
  "categories": {
    "hedging": {
      "display_name": "Hedging & qualification",
      "patterns": [
        "\\bit'?s worth (?:noting|mentioning|considering|pointing out)\\b",
        "\\bi should (?:note|mention|point out|clarify|emphasize)\\b",
        "\\bit'?s important to (?:note|recognize|acknowledge|understand)\\b",
        "\\bfrom my understanding\\b",
        "\\bto be (?:fair|clear|honest|precise|transparent)\\b",
        "\\bthat (?:said|being said)\\b",
        "\\bhaving said that\\b",
        "\\bi think it'?s (?:fair|important|worth|helpful)\\b",
        "\\bi'?d (?:argue|suggest|say|note|venture)\\b",
        "\\bit seems (?:like|that|to)\\b",
        "\\bthis is (?:a |somewhat |particularly )?nuanced\\b",
        "\\bthere'?s (?:a lot of )?nuance (?:here|to|in)\\b",
        "\\bin fairness\\b",
        "\\bwith that (?:caveat|said|in mind)\\b",
        "\\bthough (?:it'?s|this is) worth\\b",
        "\\bwhile (?:i|it'?s) (?:can'?t|don'?t|wouldn'?t|shouldn'?t)\\b",
        "\\bthat'?s (?:a |an )?(?:fair|great|good|interesting|excellent|thoughtful) (?:question|point|observation)\\b"
      ],
      "match_mode": "anywhere",
      "weight": 20,
      "multiplier": 5,
      "direction": "positive"
    },
    "balance": {
      "display_name": "Multi-perspective balance",
      "patterns": [
        "\\bon the other hand\\b",
        "\\bhowever,? (?:it'?s|there'?s|we should|one could|some)\\b",
        "\\bat the same time\\b",
        "\\bconversely\\b",
        "\\bthat said\\b",
        "\\bwhile (?:this|that|there|it) (?:is|may|might|can|has)\\b",
        "\\bbut it'?s (?:also|equally|worth)\\b",
        "\\bthere (?:are|is) (?:also |certainly )?(?:valid|good|strong|legitimate) (?:arguments?|points?|reasons?|cases?)\\b",
        "\\bfrom (?:another|a different|the other|one) perspective\\b",
        "\\b(?:some|others) (?:would|might|may|could) argue\\b",
        "\\bthe (?:picture|reality|situation|answer|truth) is (?:more )?(?:complex|complicated|nuanced|mixed)\\b",
        "\\bboth (?:sides|perspectives|viewpoints|positions)\\b",
        "\\bthe (?:flip side|counterargument|counter-?argument)\\b",
        "\\bcuts both ways\\b",
        "\\bit'?s not (?:quite )?(?:that )?(?:simple|straightforward|black and white)\\b"
      ],
      "match_mode": "anywhere",
      "weight": 15,
      "multiplier": 4,
      "direction": "positive"
    },
    "acknowledgement": {
      "display_name": "Conversational openers",
      "patterns": [
        "^(?:that'?s |what )?(?:a |an )?(?:really |very )?(?:great|good|excellent|interesting|thoughtful|fair|important|fascinating|helpful) (?:question|point|observation|insight|thought)",
        "^i (?:appreciate|understand|see|hear) (?:your|the|that|what you)",
        "^(?:yes|absolutely|indeed|certainly|right),? (?:that|this|and|so)\\b",
        "^i'?d be happy to\\b",
        "^happy to help\\b",
        "^certainly[!.]?\\s",
        "^absolutely[!.]?\\s",
        "^great question\\b",
        "^good question\\b"
      ],
      "match_mode": "line_start",
      "weight": 10,
      "multiplier": 8,
      "direction": "positive"
    },
    "vocabulary": {
      "display_name": "Claude vocabulary",
      "patterns": [
        "\\bnuanced\\b",
        "\\bstraightforward\\b",
        "\\bfascinating\\b",
        "\\bcompelling\\b",
        "\\bthoughtful(?:ly)?\\b",
        "\\bparticularly\\b",
        "\\bnotably\\b",
        "\\bgenuinely\\b",
        "\\bfundamentally\\b",
        "\\breasonabl[ey]\\b",
        "\\blegitimate(?:ly)?\\b",
        "\\bmeaningful(?:ly)?\\b",
        "\\bsubstantive(?:ly)?\\b",
        "\\bworthwhile\\b",
        "\\btricky\\b",
        "\\bsubtle(?:ty|ties)?\\b",
        "\\bgrapple(?:s|d|ing)? with\\b",
        "\\bunpack(?:s|ed|ing)?\\b",
        "\\btease(?:s|d)? (?:out|apart)\\b",
        "\\bsit(?:s|ting)? with (?:that|this|the)\\b",
        "\\bpush(?:es|ed|ing)? back (?:on|against)\\b",
        "\\bflag(?:s|ged|ging)?\\s(?:that|this|a |an |the |some)\\b",
        "\\backnowledge(?:s|d)?\\b",
        "\\bthe short (?:answer|version)\\b",
        "\\bthe (?:honest|frank|blunt) (?:answer|truth|reality)\\b",
        "\\bthe (?:key|core|central|fundamental) (?:tension|issue|question|challenge|insight)\\b",
        "\\bin practice\\b",
        "\\bin a nutshell\\b",
        "\\bat the (?:end of the day|heart of)\\b",
        "\\bthe broader (?:point|picture|context|question)\\b",
        "\\b(?:here'?s|that'?s) (?:the|where the) (?:thing|rub|catch|tension|crux)\\b"
      ],
      "match_mode": "anywhere",
      "weight": 20,
      "multiplier": 3,
      "direction": "positive"
    },
    "safety_disclaimers": {
      "display_name": "Safety/ethical disclaimers",
      "patterns": [
        "\\bi (?:should|want to|need to|have to) (?:be )?(?:upfront|transparent|honest|clear|careful)\\b",
        "\\bi (?:can'?t|don'?t|shouldn'?t|wouldn'?t) (?:provide|give|offer|make|recommend)\\b.{0,30}(?:advice|recommendation|diagnosis|judgment)",
        "\\bthis is (?:a |an )?(?:sensitive|complex|complicated|difficult|important) (?:topic|issue|area|subject|question)\\b",
        "\\bi'?m not (?:a |an )?(?:expert|lawyer|doctor|therapist|financial|medical)\\b",
        "\\bplease (?:consult|speak with|check with|talk to) (?:a |an )?(?:professional|expert|doctor|lawyer|therapist)\\b",
        "\\bi should (?:also )?(?:note|mention|acknowledge|flag|point out) that\\b",
        "\\bresponsib(?:le|ly|ility)\\b",
        "\\bethical(?:ly)?\\b",
        "\\bwith (?:that|the) caveat\\b",
        "\\bi (?:want to|should) acknowledge\\b"
      ],
      "match_mode": "anywhere",
      "weight": 10,
      "multiplier": 5,
      "direction": "positive"
    },
    "chatgpt_vocabulary": {
      "display_name": "ChatGPT vocabulary penalty",
      "patterns": [
        "\\bdelve(?:s|d)?\\s(?:into|deeper)\\b",
        "\\btapestry of\\b",
        "\\bin the (?:ever-?evolving|ever-?changing|dynamic|rapidly changing) (?:landscape|world|realm)\\b",
        "\\bever-?evolving\\b",
        "\\bunlock(?:ing|s|ed)? (?:the |your )?(?:full |true )?(?:potential|power|secrets?)\\b",
        "\\bembark(?:s|ed|ing)? on (?:a |this |the )?(?:journey|adventure|quest)\\b",
        "\\bbeacon of\\b",
        "\\ba testament to\\b",
        "\\bin the realm of\\b",
        "\\bseamless(?:ly)?\\b",
        "\\bmeticulous(?:ly)?\\b",
        "\\bpivotal\\b",
        "\\bcommendable\\b",
        "\\bunprecedented\\b",
        "\\bvibrant\\b",
        "\\bhustle and bustle\\b",
        "\\btreasure trove\\b",
        "\\bmaster the art\\b",
        "\\bgame.?changer\\b",
        "\\blet'?s (?:dive|deep dive) (?:in|into)\\b",
        "\\bin today'?s (?:digital|fast-?paced|modern|interconnected) (?:age|world|era|landscape)\\b",
        "\\bthe transformative power of\\b",
        "\\bpave the way\\b",
        "\\bholistic approach\\b",
        "\\bactionable (?:tips|insights|steps|advice)\\b",
        "\\bleverage(?:s|d|ing)?\\b",
        "\\brobust\\b",
        "\\bcutting.?edge\\b",
        "\\bharnessing?\\b"
      ],
      "match_mode": "anywhere",
      "weight": 15,
      "multiplier": 4,
      "direction": "negative"
    },
    "shared_ai_markers": {
      "display_name": "Generic AI penalty",
      "patterns": [
        "\\bcomplex and multifaceted\\b",
        "\\bintricate interplay\\b",
        "\\bplayed? a (?:crucial|vital|key|pivotal|significant|important) role\\b",
        "\\bcannot be overstated\\b",
        "\\bit is (?:important|worth|crucial|essential|vital) to (?:note|recognize|understand|remember)\\b",
        "\\bprofound impact\\b",
        "\\bcritical(?:ly)? important\\b",
        "\\bin conclusion\\b",
        "\\bin summary\\b",
        "\\bmoreover\\b",
        "\\bfurthermore\\b",
        "\\badditionally\\b",
        "\\bmultifaceted\\b",
        "\\bintricate\\b",
        "\\bunderscores?\\b"
      ],
      "match_mode": "anywhere",
      "weight": 10,
      "multiplier": 2,
      "direction": "negative"
    }
  },
  "structural": {
    "enabled": true,
    "weight": 15,
    "rules": [
      { "feature": "bullet_ratio", "thresholds": [{"max": 0.1, "points": 5}, {"max": 0.25, "points": 2}] },
      { "feature": "em_dash_rate", "thresholds": [{"min": 1.5, "points": 4}, {"min": 0.5, "points": 2}] },
      { "feature": "parenthetical_rate", "thresholds": [{"min": 1, "points": 3}, {"min": 0.3, "points": 1.5}] },
      { "feature": "sentence_length_variance", "thresholds": [{"min": 8, "points": 3}, {"min": 5, "points": 1.5}] }
    ]
  },
  "bonuses": {
    "conversational_tone": { "enabled": true, "weight": 10, "multiplier": 0.3 }
  },
  "labels": [
    {"min": 80, "label": "Peak Claude"},
    {"min": 60, "label": "Very Claudy"},
    {"min": 40, "label": "Noticeably Claudy"},
    {"min": 20, "label": "Mild Claude tendencies"},
    {"min": 0, "label": "Not particularly Claude-like"}
  ]
}
